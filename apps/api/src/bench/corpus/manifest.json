{
  "version": 2,
  "description": "Manifest for the memory bench corpus. Toy is vendored; LongMemEval + LoCoMo fetch into gitignored cache/ via pnpm bench:fetch-corpus.",
  "datasets": {
    "toy": {
      "file": "toy.json",
      "vendored": true,
      "source": "internal",
      "questions": 3
    },
    "longmemeval": {
      "file": "cache/longmemeval_oracle.json",
      "vendored": false,
      "source": "https://github.com/xiaowu0162/longmemeval",
      "fetchUrl": "https://huggingface.co/datasets/xiaowu0162/longmemeval-cleaned/resolve/main/longmemeval_oracle.json",
      "questions": 500
    },
    "locomo": {
      "file": "cache/locomo10.json",
      "vendored": false,
      "source": "https://github.com/snap-research/locomo",
      "fetchUrl": "https://raw.githubusercontent.com/snap-research/locomo/main/data/locomo10.json",
      "questions": 1540
    }
  }
}
