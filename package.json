{
  "name": "aura-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm --filter @aura/db build && pnpm --filter aura-api --filter aura-dashboard --parallel dev",
    "typecheck": "pnpm --filter aura-api typecheck && pnpm --filter aura-dashboard typecheck",
    "db:generate": "./scripts/env.sh pnpm --filter @aura/db db:generate",
    "db:migrate": "./scripts/env.sh pnpm --filter @aura/db db:migrate",
    "db:push": "./scripts/env.sh pnpm --filter @aura/db db:push",
    "db:studio": "./scripts/env.sh pnpm --filter @aura/db db:studio",
    "bench:memory": "./scripts/env.sh pnpm --filter aura-api bench:memory",
    "bench:memory:i": "./scripts/env.sh pnpm --filter aura-api bench:memory:i",
    "bench:fetch-corpus": "pnpm --filter aura-api bench:fetch-corpus",
    "bench:report": "pnpm --filter aura-api bench:report"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "e2b>chalk": "4.1.2",
      "@types/react": "19.2.14"
    }
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
